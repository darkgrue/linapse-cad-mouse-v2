#!/usr/bin/env python3
"""Watch TAP events and command responses from linapse-service."""
import asyncio
import sys
import websockets

WS_URL = "ws://localhost:13000"

async def monitor():
    print(f"Connecting to {WS_URL} ...")
    try:
        async with websockets.connect(WS_URL) as ws:
            print("Connected. Watching for events (Ctrl-C to quit).\n")
            async for msg in ws:
                msg = msg.strip()
                if msg.startswith("TAP:"):
                    parts = msg.split(":")
                    direction = parts[1] if len(parts) > 1 else "?"
                    count     = parts[2] if len(parts) > 2 else "?"
                    print(f"  TAP  {direction}:{count}")
                else:
                    print(f"  MSG  {msg}")
                sys.stdout.flush()
    except ConnectionRefusedError:
        print("ERROR: linapse-service not running on ws://localhost:13000")
        sys.exit(1)
    except KeyboardInterrupt:
        pass

asyncio.run(monitor())
