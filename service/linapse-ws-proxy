#!/usr/bin/env python3
import os
import sys
import asyncio
import logging
import struct
from pathlib import Path

# Try to import spacenav-ws modules
try:
    import spacenav_ws
    import spacenav_ws.spacenav
    import spacenav_ws.controller
    import spacenav_ws.main
    from spacenav_ws.spacenav import ButtonEvent, from_message, get_async_spacenav_socket_reader
    from spacenav_ws.controller import Controller, create_mouse_controller
    from spacenav_ws.wamp import WampSession, Prefix, Call, CallResult, Subscribe
    from fastapi import WebSocket
    import uvicorn
except ImportError as e:
    print(f"ERROR: Failed to import spacenav-ws dependencies: {e}", file=sys.stderr)
    print("Ensure you run this script with 'uv run --with spacenav-ws'", file=sys.stderr)
    sys.exit(1)

# Configure logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")

# 1. Dynamically set the socket path to the user-space runtime socket
runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
SPACENAV_SOCKET_PATH = os.path.join(runtime_dir, "spnav.sock")
spacenav_ws.spacenav.SPACENAV_SOCKET_PATH = SPACENAV_SOCKET_PATH
logging.info(f"Set SPACENAV_SOCKET_PATH to {SPACENAV_SOCKET_PATH}")

# 2. Patch start_mouse_event_stream to handle EOF and ignore button events
async def custom_start_mouse_event_stream(self):
    logging.info("Starting custom mouse event stream reader...")
    while True:
        try:
            mouse_event = await self.reader.read(32)
            if not mouse_event:
                raise ConnectionError("spacenav socket closed (EOF)")
            
            if self.focus and self.subscribed:
                nums = struct.unpack("iiiiiiii", mouse_event)
                event = from_message(list(nums))
                if event is None:
                    continue
                if isinstance(event, ButtonEvent):
                    # Ignore button events so they don't snap the view to front
                    continue
                
                if self.client_metadata["name"] in ["Onshape", "WebThreeJS Sample"]:
                    await self.update_client(event)
                else:
                    logging.warning("Unknown client: %s", self.client_metadata)
        except asyncio.CancelledError:
            break
        except Exception as e:
            logging.error(f"Error in mouse event stream: {e}")
            raise

Controller.start_mouse_event_stream = custom_start_mouse_event_stream

# 3. Patch nlproxy WebSocket endpoint in main.py to handle reconnects cleanly
async def custom_nlproxy(ws: WebSocket):
    logging.info("Handling browser connection to nlproxy...")
    wamp_session = WampSession(ws)
    
    # Try to open the socket connection, wait if needed
    spacenav_reader = None
    for _ in range(5):
        try:
            spacenav_reader, _ = await get_async_spacenav_socket_reader()
            break
        except OSError:
            await asyncio.sleep(0.5)
            
    if spacenav_reader is None:
        # Fallback to dummy reader so controller initialization doesn't crash
        spacenav_reader = asyncio.StreamReader()
        
    ctrl = await create_mouse_controller(wamp_session, spacenav_reader)
    
    async def _mouse_with_reconnect():
        while True:
            try:
                # If reader is dummy or closed, try to open a new one
                if ctrl.reader.at_eof() or ctrl.reader.feed_data == asyncio.StreamReader.feed_data:
                    logging.info("Reconnecting to spacenav socket...")
                    _r, _ = await asyncio.open_unix_connection(SPACENAV_SOCKET_PATH)
                    ctrl.reader = _r
                    logging.info("Reconnected successfully")
                
                await ctrl.start_mouse_event_stream()
            except Exception as e:
                logging.warning(f"Spacenav socket error ({e}), retrying in 1s...")
                await asyncio.sleep(1)

    async with asyncio.TaskGroup() as tg:
        tg.create_task(_mouse_with_reconnect(), name="mouse")
        tg.create_task(ctrl.wamp_state_handler.start_wamp_message_stream(), name="wamp")

# Find and replace the endpoint in the FastAPI application
app = spacenav_ws.main.app
for route in app.routes:
    if getattr(route, "path", None) == "/" and hasattr(route, "endpoint"):
        route.endpoint = custom_nlproxy
        logging.info("Successfully patched nlproxy WebSocket endpoint")

# 4. Expose the CLI serve command using uvicorn
def main():
    pkg_dir = Path(spacenav_ws.__file__).parent
    cert_file = pkg_dir / "certs" / "ip.crt"
    key_file = pkg_dir / "certs" / "ip.key"
    
    host = "127.51.68.120"
    port = 8181
    
    logging.warning(f"Starting Linapse SpaceNav WebSocket Proxy on wss://{host}:{port}")
    uvicorn.run(
        app, host=host, port=port, ws="auto",
        ssl_certfile=str(cert_file), ssl_keyfile=str(key_file),
        log_level="info"
    )

if __name__ == "__main__":
    main()
