#!/usr/bin/env python3
"""
CAD Mouse MK2 — button and tap action dispatcher.

Reads HID button events from hidraw and TAP events from the firmware's
USB serial port, then dispatches actions defined in:
  ~/.config/cad-mouse/actions.json

Action types:
  {"action": "none"}
  {"action": "key",         "value": "ctrl+z"}
  {"action": "mouse_click", "button": "left|right|middle"}
  {"action": "mouse_scroll","direction": "up|down|left|right", "amount": 3}
  {"action": "mouse_move",  "x": 0, "y": -10}
  {"action": "exec",        "value": "notify-send hello"}
  {"action": "scroll_up"}
  {"action": "scroll_down"}
  {"action": "macro",       "steps": [{...}, {"delay": 100}, ...]}

Tap keys use human direction names: top, left, right, front, back.
Key format: "<direction>:<count>"  e.g. "top:2"

button_override:
  false (default) — buttons 0/1 scroll; button_override ignored
  true            — buttons 0/1 emit raw HID; scroll handled by OS

Requires: ydotoold running, user in 'input' group, pyserial.
"""

import glob
import json
import os
import select
import serial
import subprocess
import threading
import time
from pathlib import Path

# ── Config ────────────────────────────────────────────────────────────────────

ACTIONS_PATH  = Path.home() / ".config" / "cad-mouse" / "actions.json"
YDOTOOL_SOCKET = f"/run/user/{os.getuid()}/.ydotool_socket"

BUTTON_REPORT_ID = 3
CHORD_WINDOW     = 0.05    # seconds between presses to count as chord
SCROLL_INTERVAL  = 0.05    # seconds between scroll ticks while held
SERIAL_BAUD      = 115200

# Firmware direction names → human names
DIR_MAP = {
    "NegZ": "top",
    "NegX": "left",
    "PosX": "right",
    "PosY": "front",
    "NegY": "back",
}

# ── Helpers ───────────────────────────────────────────────────────────────────

def find_hidraw():
    m = glob.glob("/dev/input/by-id/usb-Seeed_Studio_CAD_Mouse_MK2_*-if02-hidraw")
    if not m:
        raise RuntimeError("CAD Mouse MK2 hidraw not found. Plugged in? In 'input' group?")
    return m[0]

def find_serial():
    m = (glob.glob("/dev/serial/by-id/usb-Seeed_Studio_CAD_Mouse*") +
         glob.glob("/dev/ttyACM*"))
    return m[0] if m else None

def load_actions():
    try:
        with open(ACTIONS_PATH) as f:
            return json.load(f)
    except Exception as e:
        print(f"[actions] could not load {ACTIONS_PATH}: {e}")
        return {"button_override": False, "buttons": {}, "taps": {}}

# ── Dispatcher ────────────────────────────────────────────────────────────────

def ydotool(*args):
    env = os.environ.copy()
    env["YDOTOOL_SOCKET"] = YDOTOOL_SOCKET
    subprocess.run(["ydotool"] + list(args), env=env)

# ydotool button codes
_MOUSE_BTN = {"left": 0x40001, "right": 0x40002, "middle": 0x40003}

def dispatch(action_obj):
    if not action_obj:
        return
    act = action_obj.get("action", "none")

    if act == "none":
        pass

    elif act == "key":
        val = action_obj.get("value", "")
        if val:
            ydotool("key", val)

    elif act == "mouse_click":
        btn = action_obj.get("button", "left")
        code = _MOUSE_BTN.get(btn, 0x40001)
        ydotool("click", hex(code))

    elif act == "mouse_scroll":
        direction = action_obj.get("direction", "down")
        amount    = int(action_obj.get("amount", 3))
        if direction in ("up", "down"):
            delta = -amount if direction == "up" else amount
            ydotool("mousemove", "-w", "--", "0", str(delta))
        else:
            delta = -amount if direction == "left" else amount
            ydotool("mousemove", "-w", "--", str(delta), "0")

    elif act == "mouse_move":
        x = int(action_obj.get("x", 0))
        y = int(action_obj.get("y", 0))
        ydotool("mousemove", "--", str(x), str(y))

    elif act in ("scroll_up", "scroll_down"):
        delta = -3 if act == "scroll_up" else 3
        ydotool("mousemove", "-w", "--", "0", str(delta))

    elif act == "exec":
        val = action_obj.get("value", "")
        if val:
            subprocess.Popen(val, shell=True)

    elif act == "macro":
        for step in action_obj.get("steps", []):
            if "delay" in step:
                time.sleep(step["delay"] / 1000.0)
            else:
                dispatch(step)

# ── Button handler ────────────────────────────────────────────────────────────

held        = set()
chord_fired = False
timers      = {}
scroll_threads = {}

def scroll_loop(btn, stop_event, actions):
    act = actions.get("buttons", {}).get(str(btn), {"action": "scroll_down" if btn == 0 else "scroll_up"})
    while not stop_event.is_set():
        dispatch(act)
        time.sleep(SCROLL_INTERVAL)

def on_single(btn, actions):
    global chord_fired
    if chord_fired:
        return
    override = actions.get("button_override", False)
    if override:
        return  # raw HID passthrough — OS handles it
    act = actions.get("buttons", {}).get(str(btn), {"action": "scroll_down" if btn == 0 else "scroll_up"})
    if act.get("action") in ("scroll_up", "scroll_down"):
        stop_event = threading.Event()
        t = threading.Thread(target=scroll_loop, args=(btn, stop_event, actions), daemon=True)
        scroll_threads[btn] = (t, stop_event)
        t.start()
    else:
        dispatch(act)

def on_chord(actions):
    act = actions.get("buttons", {}).get("chord", {"action": "key", "value": "shift+7"})
    dispatch(act)

def on_press(btn, actions):
    global chord_fired
    held.add(btn)
    if len(held) == 2:
        chord_fired = True
        for t in timers.values():
            t.cancel()
        timers.clear()
        on_chord(actions)
        return
    t = threading.Timer(CHORD_WINDOW, on_single, args=[btn, actions])
    timers[btn] = t
    t.start()

def on_release(btn):
    global chord_fired
    held.discard(btn)
    if btn in timers:
        timers.pop(btn).cancel()
    if btn in scroll_threads:
        _, stop_event = scroll_threads.pop(btn)
        stop_event.set()
    if not held:
        chord_fired = False

# ── Serial TAP reader ─────────────────────────────────────────────────────────

def serial_reader(actions_ref):
    port = find_serial()
    if not port:
        print("[serial] no serial port found — tap dispatch disabled")
        return
    while True:
        try:
            ser = serial.Serial(port, SERIAL_BAUD, timeout=1.0)
            print(f"[serial] connected to {port}")
            while True:
                line = ser.readline().decode(errors="replace").strip()
                if not line.startswith("TAP:"):
                    continue
                parts = line.split(":")
                if len(parts) != 3:
                    continue
                _, fw_dir, count_str = parts
                human = DIR_MAP.get(fw_dir)
                if not human:
                    continue
                key = f"{human}:{count_str}"
                act = actions_ref[0].get("taps", {}).get(key)
                if act:
                    print(f"[tap] {key} → {act}")
                    dispatch(act)
        except serial.SerialException as e:
            print(f"[serial] {e} — retrying in 3s")
            time.sleep(3)
        except Exception as e:
            print(f"[serial] unexpected error: {e} — retrying in 3s")
            time.sleep(3)

# ── Config watcher ────────────────────────────────────────────────────────────

def config_watcher(actions_ref):
    last_mtime = 0
    while True:
        try:
            mtime = ACTIONS_PATH.stat().st_mtime
            if mtime != last_mtime:
                last_mtime = mtime
                actions_ref[0] = load_actions()
                print(f"[config] reloaded {ACTIONS_PATH}")
        except FileNotFoundError:
            pass
        time.sleep(2)

# ── Main ──────────────────────────────────────────────────────────────────────

actions_ref = [load_actions()]

threading.Thread(target=serial_reader,  args=(actions_ref,), daemon=True).start()
threading.Thread(target=config_watcher, args=(actions_ref,), daemon=True).start()

fd = open(find_hidraw(), "rb")
os.set_blocking(fd.fileno(), False)
prev_bits = 0

print(f"[buttons] watching {fd.name}")
while True:
    r, _, _ = select.select([fd], [], [], 1)
    if not r:
        continue
    data = fd.read(64)
    if not data or data[0] != BUTTON_REPORT_ID:
        continue
    bits = data[1] & 0x03
    if bits == prev_bits:
        continue
    for btn in range(2):
        mask = 1 << btn
        was  = bool(prev_bits & mask)
        now  = bool(bits & mask)
        if now and not was:
            on_press(btn, actions_ref[0])
        elif was and not now:
            on_release(btn)
    prev_bits = bits
