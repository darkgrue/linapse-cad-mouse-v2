# Image for running the Python test suite in isolation on a dev machine.
# Mirrors the dependency set CI installs (see .github/workflows/multi-distro-test.yml).
# Repo code is bind-mounted at run time, so this image only carries dependencies
# and is rebuilt only when they change.
FROM python:3.12-slim

RUN pip install --no-cache-dir \
        pytest websockets pyserial pyyaml fastapi "uvicorn[standard]" numpy scipy playwright \
    && playwright install --with-deps chromium

WORKDIR /repo/service
